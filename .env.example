# ══════════════════════════════════════════════════════════════════════════════
# EMPLIX BACKEND — Variables de Entorno
# ══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env (local) o configura directamente en Railway.
# NUNCA subas .env con valores reales a git.
#
# Generar JWT_SECRET:  openssl rand -hex 32

# ── Base de datos ──────────────────────────────────────────────────────────────
# Neon.tech / Railway Postgres / local:
#   Producción: agrega ?sslmode=require al final
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require

# ── Autenticación ──────────────────────────────────────────────────────────────
# Mínimo 64 caracteres aleatorios. NUNCA uses una frase legible en producción.
JWT_SECRET=CHANGE_ME_MIN_64_RANDOM_CHARS_USE_openssl_rand_hex_32

# ── Azure Entra ID (Microsoft SSO) ────────────────────────────────────────────
# Crear App Registration en portal.azure.com para cada entorno (DEV / PROD)
# Redirect URI de producción: https://TU_DOMINIO/auth-redirect.html
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Azure Blob Storage ─────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name

# ── CORS ──────────────────────────────────────────────────────────────────────
# Dominio(s) exacto(s) del frontend en producción, separados por coma si hay varios.
# Ej Azure: https://tu-app.azurestaticapps.net,https://tu-dominio.com
# Ej local: (dejar vacío — se permite todo en NODE_ENV=development)
CORS_ORIGIN=https://TU-FRONTEND.azurestaticapps.net

# ── Servidor ───────────────────────────────────────────────────────────────────
# Azure App Service sobreescribe PORT automáticamente via WEBSITES_PORT o PORT
PORT=3000
NODE_ENV=production
