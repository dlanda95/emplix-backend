// ── Tenant Schema ──────────────────────────────────────────────────────────────
// Tablas de RRHH. Cada empresa vive en su propio schema de PostgreSQL.
// Schema naming: tenant_{slug_sin_guiones}  ej: tenant_acme_corp
// La URL de conexión se sobreescribe en runtime por TenantPrismaManager.
// Para generar el cliente: prisma generate --schema=prisma/tenant.prisma
// Para obtener el DDL:     prisma migrate diff --from-empty --to-schema-datamodel prisma/tenant.prisma --script

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/tenant-client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  COMPANY_ADMIN
  HR_MANAGER
  HR_ANALYST
  AREA_MANAGER
  EMPLOYEE
}

enum Provider {
  LOCAL
  MICROSOFT
  GOOGLE
}

enum EmployeeStatus {
  SELECTED // Candidato en proceso de onboarding
  ACTIVE
  TERMINATED
  ON_LEAVE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestType {
  VACATION
  PERMIT
  SICK_LEAVE
  HOME_OFFICE
  PROFILE_UPDATE
}

enum DocumentType {
  AVATAR
  CONTRACT
  ID_CARD
  CERTIFICATION
  MEDICAL
  OTHER
}

enum AttendanceSource {
  BIOMETRIC
  MOBILE_APP
  WEB_PORTAL
  SYSTEM_AUTO
  MANUAL_HR
}

enum AttendanceStatus {
  PENDING
  PRESENT_ON_TIME
  LATE
  ABSENT_JUSTIFIED
  ABSENT_UNJUSTIFIED
  VACATION
  MEDICAL_LEAVE
  HOLIDAY
  DAY_OFF
}

enum FamilyRelationship {
  FATHER
  MOTHER
  GUARDIAN
  SPOUSE
  PARTNER
  SON
  DAUGHTER
  SIBLING
  DEPENDENT
  HEIR
  OTHER
}

// ── System User Types (catalog) ───────────────────────────────────────────────

model SystemUserType {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  permissions Json     @default("{}")
  color       String   @default("#6B7280")
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("system_user_types")
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String?
  provider           Provider  @default(LOCAL)
  providerId         String?
  role               UserRole  @default(EMPLOYEE)
  firstName          String?
  lastName           String?
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  systemUserTypeId String?
  systemUserType   SystemUserType? @relation(fields: [systemUserTypeId], references: [id])

  employee            Employee?
  requests            Request[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ── Organization ──────────────────────────────────────────────────────────────

enum AreaType {
  TRANSVERSAL
  EMISSIVE
  RECEPTIVE
}

enum RoleType {
  OPERATIONAL
  TACTICAL
  STRATEGIC
}

model Department {
  id          String       @id @default(uuid())
  name        String
  code        String?      @unique
  description String?
  areaType    AreaType     @default(TRANSVERSAL)
  isActive    Boolean      @default(true)
  parentId    String?
  parent      Department?  @relation("AreaHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("AreaHierarchy")
  leaderId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  employees          Employee[]
  positions          Position[]
  selectionProcesses SelectionProcess[] @relation("ProcessDept")

  @@index([parentId])
  @@map("departments")
}

model Position {
  id             String      @id @default(uuid())
  name           String      @unique
  description    String?
  hierarchyLevel Int         @default(1)
  roleType       RoleType    @default(OPERATIONAL)
  isActive       Boolean     @default(true)
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  employees          Employee[]
  selectionProcesses SelectionProcess[] @relation("ProcessPosition")

  @@map("positions")
}

// ── Labor Config ──────────────────────────────────────────────────────────────

model ContractType {
  id          String  @id @default(uuid())
  name        String  @unique
  code        String?
  hasBenefits Boolean @default(true)
  isLaboral   Boolean @default(true)

  employees EmployeeLaborData[]

  @@map("contract_types")
}

model WorkShift {
  id             String  @id @default(uuid())
  name           String  @unique
  isFiscalized   Boolean @default(true)
  startTime      String?
  endTime        String?
  breakTime      Int     @default(60)
  tolerance      Int     @default(5)
  allowsOvertime Boolean @default(false)

  employees EmployeeLaborData[]

  @@map("work_shifts")
}

// ── Procesos de Selección ─────────────────────────────────────────────────────

enum SelectionProcessStatus {
  OPEN // Activo — acepta candidatos
  CLOSED // Cerrado — proceso finalizado
  CANCELLED // Cancelado
}

model SelectionProcess {
  id          String                 @id @default(uuid())
  code        String                 @unique
  name        String
  description String?
  status      SelectionProcessStatus @default(OPEN)
  openedAt    DateTime               @default(now())
  closedAt    DateTime?
  createdById String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  departmentId String?
  department   Department? @relation("ProcessDept", fields: [departmentId], references: [id])

  positionId String?
  position   Position? @relation("ProcessPosition", fields: [positionId], references: [id])

  candidates         Employee[]
  approvers          SelectionProcessApprover[]
  candidateApprovals CandidateApproval[]        @relation("ProcessCandidateApprovals")
  hrAnalyses         HRCandidateAnalysis[]

  @@index([status])
  @@index([code])
  @@map("selection_processes")
}

model SelectionProcessApprover {
  id                 String           @id @default(uuid())
  selectionProcessId String
  selectionProcess   SelectionProcess @relation(fields: [selectionProcessId], references: [id], onDelete: Cascade)
  employeeId         String
  employee           Employee         @relation("SPApprover", fields: [employeeId], references: [id], onDelete: Cascade)
  order              Int
  createdAt          DateTime         @default(now())

  @@unique([selectionProcessId, employeeId])
  @@index([selectionProcessId])
  @@map("selection_process_approvers")
}

// ── Employees ─────────────────────────────────────────────────────────────────

model Employee {
  id               String         @id @default(uuid())
  firstName        String
  middleName       String?
  lastName         String
  secondLastName   String?
  birthDate        DateTime?
  documentId       String?        @unique
  gender           String?
  maritalStatus    String?
  nationality      String?
  academicLevel    String?
  birthCountry     String?
  birthRegion      String?
  birthDistrict    String?
  licenseNumber    String?
  documentType     String?        @default("DNI")
  onboardingStatus String?
  personalEmail    String?
  phone            String?
  cellPhone        String?
  address          String?
  district         String?
  province         String?
  departmentdirec  String?
  addressRef       String?
  docAddress       String?
  docDistrict      String?
  docDepartment    String?
  docAddressRef    String?
  emergencyName    String?
  emergencyPhone   String?
  emergencyRel     String?
  afpType          String?
  afpEntity        String?
  afpCommission    String?
  bankEntity       String?
  bankAccount      String?
  bankCci          String?
  status           EmployeeStatus @default(ACTIVE)
  hireDate         DateTime

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  supervisorId String?
  supervisor   Employee?  @relation("Hierarchy", fields: [supervisorId], references: [id])
  subordinates Employee[] @relation("Hierarchy")

  selectionProcessId String?
  selectionProcess   SelectionProcess? @relation(fields: [selectionProcessId], references: [id])

  laborData         EmployeeLaborData?
  attendances       Attendance[]
  documents         Document[]
  requests          Request[]
  familyMembers     FamilyMember[]
  educations        Education[]
  sentKudos         Kudo[]                     @relation("Sender")
  receivedKudos     Kudo[]                     @relation("Receiver")
  approvals         SelectionProcessApprover[] @relation("SPApprover")
  receivedApprovals CandidateApproval[]        @relation("CandidateApprovals")
  hrAnalyses        HRCandidateAnalysis[]      @relation("HRAnalysis")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([supervisorId])
  @@map("employees")
}

model CandidateApproval {
  id                 String           @id @default(uuid())
  selectionProcessId String
  selectionProcess   SelectionProcess @relation("ProcessCandidateApprovals", fields: [selectionProcessId], references: [id], onDelete: Cascade)
  candidateId        String
  candidate          Employee         @relation("CandidateApprovals", fields: [candidateId], references: [id], onDelete: Cascade)
  approverId         String // user.id del JWT — válido para EMPLOYEE y HR
  approverType       String // 'APPROVER' | 'HR'
  status             String           @default("PENDING") // 'PENDING' | 'APPROVED' | 'REJECTED'
  comment            String?
  decidedAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([selectionProcessId, candidateId, approverId])
  @@index([selectionProcessId, candidateId])
  @@index([approverId])
  @@map("candidate_approvals")
}

model EmployeeLaborData {
  id             String       @id @default(uuid())
  employeeId     String       @unique
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  contractTypeId String
  contractType   ContractType @relation(fields: [contractTypeId], references: [id])
  workShiftId    String
  workShift      WorkShift    @relation(fields: [workShiftId], references: [id])
  hierarchyLevel String
  startDate      DateTime
  endDate        DateTime?
  salary         Decimal      @default(0.0)
  currency       String       @default("PEN")

  @@map("employee_labor_data")
}

// ── Attendance ────────────────────────────────────────────────────────────────

model Attendance {
  id          String           @id @default(uuid())
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  source      AttendanceSource @default(BIOMETRIC)
  status      AttendanceStatus @default(PENDING)
  hoursWorked Decimal?         @default(0)
  isManual    Boolean          @default(false)
  editedBy    String?
  editReason  String?

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendances")
}

// ── Requests ──────────────────────────────────────────────────────────────────

model Request {
  id        String        @id @default(uuid())
  type      RequestType
  status    RequestStatus @default(PENDING)
  startDate DateTime?
  endDate   DateTime?
  reason    String?
  data      Json?

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("requests")
}

// ── Kudos ─────────────────────────────────────────────────────────────────────

model Kudo {
  id           String @id @default(uuid())
  message      String
  categoryCode String

  senderId String
  sender   Employee @relation("Sender", fields: [senderId], references: [id])

  receiverId String
  receiver   Employee @relation("Receiver", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("kudos")
}

// ── Documents ─────────────────────────────────────────────────────────────────

model Document {
  id           String       @id @default(uuid())
  name         String
  originalName String?
  mimeType     String
  size         Int
  path         String
  type         DocumentType @default(OTHER)
  isPublic     Boolean      @default(false)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  uploadedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId])
  @@index([type])
  @@map("documents")
}

// ── Education ─────────────────────────────────────────────────────────────────

model Education {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  level       String
  institution String
  program     String
  startYear   Int
  endYear     Int?
  status      String   @default("COMPLETED")
  country     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("educations")
}

// ── Family ────────────────────────────────────────────────────────────────────

model FamilyMember {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  firstName    String
  lastName     String
  relationship FamilyRelationship
  documentType String             @default("DNI")
  documentId   String?
  birthDate    DateTime?
  phone        String?
  isDependent  Boolean            @default(false)
  isHeir       Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("family_members")
}

// ── Análisis de RR.HH. por candidato ─────────────────────────────────────────

enum HRRecommendation {
  PENDING
  APPROVED
  CONDITIONALLY_APPROVED
  REJECTED
}

model HRCandidateAnalysis {
  id                 String @id @default(uuid())
  selectionProcessId String
  candidateId        String

  professionalSummary  String?          @db.Text
  strengths            String?          @db.Text
  improvementAreas     String?          @db.Text
  interviewResults     String?          @db.Text
  competencyEvaluation String?          @db.Text
  identifiedRisks      String?          @db.Text
  recommendation       HRRecommendation @default(PENDING)
  recommendationNotes  String?          @db.Text
  salaryExpectation    Decimal?         @db.Decimal(12, 2)

  documents HRAnalysisDocument[]

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  selectionProcess SelectionProcess @relation(fields: [selectionProcessId], references: [id], onDelete: Cascade)
  candidate        Employee         @relation("HRAnalysis", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([selectionProcessId, candidateId])
  @@map("hr_candidate_analyses")
}

model HRAnalysisDocument {
  id           String              @id @default(uuid())
  analysisId   String
  name         String
  originalName String
  mimeType     String
  size         Int
  path         String
  analysis     HRCandidateAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  uploadedById String?
  createdAt    DateTime            @default(now())

  @@map("hr_analysis_documents")
}

// ── Dominios corporativos ─────────────────────────────────────────────────────

model TenantDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  label     String? // Nombre amigable, ej: "Condor Travel"
  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenant_domains")
}
