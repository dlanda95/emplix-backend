// ── Tenant Schema ──────────────────────────────────────────────────────────────
// Tablas de RRHH. Cada empresa vive en su propio schema de PostgreSQL.
// Schema naming: tenant_{slug_sin_guiones}  ej: tenant_acme_corp
// La URL de conexión se sobreescribe en runtime por TenantPrismaManager.
// Para generar el cliente: prisma generate --schema=prisma/tenant.prisma
// Para obtener el DDL:     prisma migrate diff --from-empty --to-schema-datamodel prisma/tenant.prisma --script

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/tenant-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  COMPANY_ADMIN
  HR_MANAGER
  HR_ANALYST
  AREA_MANAGER
  EMPLOYEE
}

enum Provider {
  LOCAL
  MICROSOFT
  GOOGLE
}

enum EmployeeStatus {
  ACTIVE
  TERMINATED
  ON_LEAVE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestType {
  VACATION
  PERMIT
  SICK_LEAVE
  HOME_OFFICE
  PROFILE_UPDATE
}

enum DocumentType {
  AVATAR
  CONTRACT
  ID_CARD
  CERTIFICATION
  MEDICAL
  OTHER
}

enum AttendanceSource {
  BIOMETRIC
  MOBILE_APP
  WEB_PORTAL
  SYSTEM_AUTO
  MANUAL_HR
}

enum AttendanceStatus {
  PENDING
  PRESENT_ON_TIME
  LATE
  ABSENT_JUSTIFIED
  ABSENT_UNJUSTIFIED
  VACATION
  MEDICAL_LEAVE
  HOLIDAY
  DAY_OFF
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  provider     Provider  @default(LOCAL)
  providerId   String?
  role         UserRole  @default(EMPLOYEE)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee Employee?
  requests Request[]

  @@map("users")
}

// ── Organization ──────────────────────────────────────────────────────────────

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String?  @unique
  description String?
  leaderId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[]
  positions Position[]

  @@map("departments")
}

model Position {
  id           String      @id @default(uuid())
  name         String      @unique
  description  String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  employees Employee[]

  @@map("positions")
}

// ── Labor Config ──────────────────────────────────────────────────────────────

model ContractType {
  id          String  @id @default(uuid())
  name        String  @unique
  code        String?
  hasBenefits Boolean @default(true)
  isLaboral   Boolean @default(true)

  employees EmployeeLaborData[]

  @@map("contract_types")
}

model WorkShift {
  id             String  @id @default(uuid())
  name           String  @unique
  isFiscalized   Boolean @default(true)
  startTime      String?
  endTime        String?
  breakTime      Int     @default(60)
  tolerance      Int     @default(5)
  allowsOvertime Boolean @default(false)

  employees EmployeeLaborData[]

  @@map("work_shifts")
}

// ── Employees ─────────────────────────────────────────────────────────────────

model Employee {
  id             String         @id @default(uuid())
  firstName      String
  middleName     String?
  lastName       String
  secondLastName String?
  birthDate      DateTime?
  documentId     String?        @unique
  gender         String?
  personalEmail  String?
  phone          String?
  address        String?
  emergencyName  String?
  emergencyPhone String?
  emergencyRel   String?
  status         EmployeeStatus @default(ACTIVE)
  hireDate       DateTime

  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  positionId   String?
  position     Position?   @relation(fields: [positionId], references: [id])

  supervisorId  String?
  supervisor    Employee?  @relation("Hierarchy", fields: [supervisorId], references: [id])
  subordinates  Employee[] @relation("Hierarchy")

  laborData     EmployeeLaborData?
  attendances   Attendance[]
  documents     Document[]
  requests      Request[]
  sentKudos     Kudo[] @relation("Sender")
  receivedKudos Kudo[] @relation("Receiver")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([supervisorId])
  @@map("employees")
}

model EmployeeLaborData {
  id             String   @id @default(uuid())
  employeeId     String   @unique
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  contractTypeId String
  contractType   ContractType @relation(fields: [contractTypeId], references: [id])
  workShiftId    String
  workShift      WorkShift    @relation(fields: [workShiftId], references: [id])
  hierarchyLevel String
  startDate      DateTime
  endDate        DateTime?
  salary         Decimal  @default(0.0)
  currency       String   @default("PEN")

  @@map("employee_labor_data")
}

// ── Attendance ────────────────────────────────────────────────────────────────

model Attendance {
  id          String           @id @default(uuid())
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  source      AttendanceSource @default(BIOMETRIC)
  status      AttendanceStatus @default(PENDING)
  hoursWorked Decimal?         @default(0)
  isManual    Boolean          @default(false)
  editedBy    String?
  editReason  String?

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendances")
}

// ── Requests ──────────────────────────────────────────────────────────────────

model Request {
  id        String        @id @default(uuid())
  type      RequestType
  status    RequestStatus @default(PENDING)
  startDate DateTime?
  endDate   DateTime?
  reason    String?
  data      Json?

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("requests")
}

// ── Kudos ─────────────────────────────────────────────────────────────────────

model Kudo {
  id           String   @id @default(uuid())
  message      String
  categoryCode String

  senderId   String
  sender     Employee @relation("Sender",   fields: [senderId],   references: [id])

  receiverId String
  receiver   Employee @relation("Receiver", fields: [receiverId], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("kudos")
}

// ── Documents ─────────────────────────────────────────────────────────────────

model Document {
  id           String       @id @default(uuid())
  name         String
  originalName String?
  mimeType     String
  size         Int
  path         String
  type         DocumentType @default(OTHER)
  isPublic     Boolean      @default(false)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  uploadedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId])
  @@index([type])
  @@map("documents")
}
